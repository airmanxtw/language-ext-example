{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Console App",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/language-ext-example/bin/Debug/net8.0/language-ext-example.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Launch Console App (External Terminal)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/language-ext-example/bin/Debug/net8.0/language-ext-example.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "externalTerminal",
            "stopAtEntry": false
        },
        {
            "name": "Launch Tests",
            "type": "coreclr", 
            "request": "launch",
            "preLaunchTask": "test-build",
            "program": "dotnet",
            "args": ["test", "${workspaceFolder}/test-language-ext-example/test-language-ext-example.csproj"],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false
        }
    ]
}